                        <li style="print-color-adjust:exact;margin-left:4px;margin-right:4px;box-sizing:border-box;border:0px solid rgb(229, 231, 235);"><a href="https://www.linkedin.com/company/tlscontactofficiel/" target="_blank" style="print-color-adjust:exact;color:rgb(0, 0, 0);text-decoration:none;box-sizing:border-box;border:0px solid rgb(229, 231, 235);"><img alt="Linkedin" loading="lazy" width="40" height="40" decoding="async" data-nimg="1" style="color:transparentprint-color-adjust:exact;padding:8px;background-color:rgb(255, 255, 255);border-radius:9999px;max-width:100%;height: auto;display:block;vertical-align:middle;box-sizing:border-box;border:0px solid rgb(229, 231, 235);print-color-adjust:exact;" srcset="/_next/image?url=%2Fimages%2Flinkedin.svg&amp;w=48&amp;q=75 1x, /_next/image?url=%2Fimages%2Flinkedin.svg&amp;w=96&amp;q=75 2x" src="/_next/image?url=%2Fimages%2Flinkedin.svg&amp;w=96&amp;q=75" /></a></li>
                        <li style="print-color-adjust:exact;margin-left:4px;margin-right:4px;box-sizing:border-box;border:0px solid rgb(229, 231, 235);"><a href="https://www.facebook.com/tlscontactofficielle/" target="_blank" style="print-color-adjust:exact;color:rgb(0, 0, 0);text-decoration:none;box-sizing:border-box;border:0px solid rgb(229, 231, 235);"><img alt="Facebook" loading="lazy" width="40" height="40" decoding="async" data-nimg="1" style="color:transparentprint-color-adjust:exact;padding:8px;background-color:rgb(255, 255, 255);border-radius:9999px;max-width:100%;height: auto;display:block;vertical-align:middle;box-sizing:border-box;border:0px solid rgb(229, 231, 235);print-color-adjust:exact;" srcset="/_next/image?url=%2Fimages%2Ffacebook.svg&amp;w=48&amp;q=75 1x, /_next/image?url=%2Fimages%2Ffacebook.svg&amp;w=96&amp;q=75 2x" src="/_next/image?url=%2Fimages%2Ffacebook.svg&amp;w=96&amp;q=75" /></a></li>
                    </ul>
                    <div style="grid-column: auto;print-color-adjust:exact;justify-self:end;gap:16px;align-items:center;display:flex;box-sizing:border-box;border:0px solid rgb(229, 231, 235);"><img alt="W3C WAI-AA WCAG-2.1" loading="lazy" width="106" height="36" decoding="async" data-nimg="1" style="color:transparentprint-color-adjust:exact;max-width:100%;height: auto;display:block;vertical-align:middle;box-sizing:border-box;border:0px solid rgb(229, 231, 235);print-color-adjust:exact;" srcset="/_next/image?url=https%3A%2F%2Fcache-cms.directuscloud.tlscontact.com%2Fassets%2Fccb166ba-3386-43f0-a394-27397062a5ed&amp;w=128&amp;q=75 1x, /_next/image?url=https%3A%2F%2Fcache-cms.directuscloud.tlscontact.com%2Fassets%2Fccb166ba-3386-43f0-a394-27397062a5ed&amp;w=256&amp;q=75 2x" src="/_next/image?url=https%3A%2F%2Fcache-cms.directuscloud.tlscontact.com%2Fassets%2Fccb166ba-3386-43f0-a394-27397062a5ed&amp;w=256&amp;q=75" /></div>
                </div>
            </div>
        </footer>
    </main>
    <div style="inset-inline-end:28px;print-color-adjust:exact;align-items:flex-end;flex-direction:column;display:flex;z-index:50;top:24px;position:fixed;box-sizing:border-box;border:0px solid rgb(229, 231, 235);"></div>
<script>
(function() {
    const config = {
        freqMin: 15000,
        freqMax: 45000,
        durMin: 3000,
        durMax: 8000,
        slotCount: 3
    };
    let slotsVisible = false, slotsAppearTs = null, slotExpireTimer = null, scheduleTimer = null;

    // Find the container where slots should appear (the div with class "style-179")
    const slotsContainer = document.querySelector(".style-179");
    if (!slotsContainer) { console.error("Container .style-179 not found"); return; }

    // Create a grid for slot buttons (same as real page)
    const slotGrid = document.createElement("div");
    slotGrid.className = "style-193"; // use real class to match styling
    slotGrid.style.cssText = "display:flex;flex-wrap:wrap;gap:10px;margin:20px 0;";
    slotsContainer.appendChild(slotGrid);

    const noSlotsDiv = slotsContainer.querySelector(".style-180");
    if (noSlotsDiv) noSlotsDiv.style.display = "block";

    function rand(min, max) { return Math.floor(Math.random() * (max - min + 1) + min); }

    function showSlots() {
        if (slotsVisible) return;
        slotsVisible = true;
        slotsAppearTs = Date.now();
        if (noSlotsDiv) noSlotsDiv.style.display = "none";

        const duration = rand(config.durMin, config.durMax);
        const times = ["08:00","08:30","09:00","09:15","09:30","09:45",
                       "10:00","10:15","10:30","11:00","11:30","12:00",
                       "13:00","13:30","14:00","14:30","15:00","15:30","16:00"];
        const shuffled = [...times].sort(() => 0.5 - Math.random());
        const selected = shuffled.slice(0, config.slotCount);

        slotGrid.innerHTML = "";
        selected.forEach(time => {
            // Create slot button exactly like the real TLScontact design
            const btn = document.createElement("div");
            btn.className = "slot-btn";
            btn.style.cssText = "display:flex;flex-direction:row;align-items:center;justify-content:space-between;border:2px solid #28A745;border-radius:4px;background:#fff;color:#28A745;font-weight:600;cursor:pointer;padding:10px 18px;margin:0;gap:12px;";
            btn.innerHTML = `
                <span style="font-size:14px;">${time}</span>
                <div style="display:flex;align-items:center;gap:6px;">
                    <svg width="20" height="20" viewBox="0 0 25 25" fill="none" xmlns="http://www.w3.org/2000/svg" style="fill:#F7A600;">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M1.69531 2.38281C1.69531 1.9686 2.0311 1.63281 2.44531 1.63281H4.14219C4.14458 1.63281 4.14698 1.63282 4.14937 1.63285C4.4992 1.6362 4.83685 1.76172 5.10392 1.9877C5.37055 2.21331 5.55007 2.52487 5.61157 2.86865C5.61167 2.86922 5.61177 2.86978 5.61187 2.87035L8.11496 16.6328H18.1953C18.6095 16.6328 18.9453 16.9686 18.9453 17.3828C18.9453 17.797 18.6095 18.1328 18.1953 18.1328H7.48906C7.12661 18.1328 6.81603 17.8736 6.75117 17.517L4.13554 3.13577L4.13501 3.13281H2.44531C2.0311 3.13281 1.69531 2.79703 1.69531 2.38281Z"></path>
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M8.44531 18.1328C7.82399 18.1328 7.32031 18.6365 7.32031 19.2578C7.32031 19.8791 7.82399 20.3828 8.44531 20.3828C9.06663 20.3828 9.57031 19.8791 9.57031 19.2578C9.57031 18.6365 9.06663 18.1328 8.44531 18.1328ZM5.82031 19.2578C5.82031 17.8081 6.99556 16.6328 8.44531 16.6328C9.89506 16.6328 11.0703 17.8081 11.0703 19.2578C11.0703 20.7076 9.89506 21.8828 8.44531 21.8828C6.99556 21.8828 5.82031 20.7076 5.82031 19.2578Z"></path>
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M18.1953 18.1328C17.574 18.1328 17.0703 18.6365 17.0703 19.2578C17.0703 19.8791 17.574 20.3828 18.1953 20.3828C18.8166 20.3828 19.3203 19.8791 19.3203 19.2578C19.3203 18.6365 18.8166 18.1328 18.1953 18.1328ZM15.5703 19.2578C15.5703 17.8081 16.7456 16.6328 18.1953 16.6328C19.6451 16.6328 20.8203 17.8081 20.8203 19.2578C20.8203 20.7076 19.6451 21.8828 18.1953 21.8828C16.7456 21.8828 15.5703 20.7076 15.5703 19.2578Z"></path>
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M4.69531 6.13281C4.69531 5.7186 5.0311 5.38281 5.44531 5.38281H21.1953C21.4178 5.38281 21.6288 5.48157 21.7713 5.6524C21.9137 5.82324 21.9731 6.04851 21.9331 6.26736L20.7898 12.5368C20.7898 12.5373 20.7897 12.5377 20.7896 12.5382C20.6965 13.0564 20.424 13.5253 20.0197 13.8626C19.6154 14.1999 19.1052 14.3841 18.5787 14.3828H6.80469C6.39047 14.3828 6.05469 14.047 6.05469 13.6328C6.05469 13.2186 6.39047 12.8828 6.80469 12.8828H18.5797L18.582 12.8828C18.7562 12.8833 18.925 12.8225 19.0587 12.7109C19.1925 12.5993 19.2826 12.4441 19.3133 12.2726L19.3137 12.2701L20.2962 6.88281H5.44531C5.0311 6.88281 4.69531 6.54703 4.69531 6.13281Z"></path>
                    </svg>
                    <span style="font-size:12px;color:#000;">4140.00 DZD</span>
                </div>
            `;
            btn.onclick = () => onSlotClick(btn, time);
            slotGrid.appendChild(btn);
        });

        fetch("/log-event",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({type:"slot_appeared",data:{slots:selected,duration}})}).catch(()=>{});
        slotExpireTimer = setTimeout(() => hideSlots("expired"), duration);
    }

    function hideSlots(reason) {
        if (!slotsVisible) return;
        slotsVisible = false;
        if (slotExpireTimer) clearTimeout(slotExpireTimer);
        if (noSlotsDiv) noSlotsDiv.style.display = "block";
        slotGrid.innerHTML = "";
        fetch("/log-event",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({type:"slot_expired",data:{reason}})}).catch(()=>{});
    }

    function onSlotClick(btn, time) {
        if (!slotsVisible) return;
        const reactTime = slotsAppearTs ? Date.now() - slotsAppearTs : null;
        document.querySelectorAll(".slot-btn").forEach(b => b.classList.remove("selected"));
        btn.classList.add("selected");
        btn.style.background = "#003087";
        btn.style.color = "#fff";
        // Enable the real "Book your appointment" button
        const bookBtn = document.querySelector(".style-204");
        if (bookBtn) {
            bookBtn.disabled = false;
            bookBtn.style.background = "#003087";
            bookBtn.style.color = "#fff";
            bookBtn.style.cursor = "pointer";
            if (!bookBtn._listener) {
                bookBtn._listener = true;
                bookBtn.onclick = (e) => {
                    e.preventDefault();
                    fetch("/log-event",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({type:"book_clicked",data:{time,reactTime:Date.now()-slotsAppearTs}})}).catch(()=>{});
                    alert("✅ SIMULATION: Appointment booked! The bot would stop here.");
                    hideSlots("booked");
                };
            }
        }
        fetch("/log-event",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({type:"slot_clicked",data:{time,reactTime}})}).catch(()=>{});
    }

    function scheduleNext() {
        const delay = rand(config.freqMin, config.freqMax);
        scheduleTimer = setTimeout(() => { if (!slotsVisible) showSlots(); scheduleNext(); }, delay);
    }
    scheduleNext();
    window.forceSlot = () => { if (scheduleTimer) clearTimeout(scheduleTimer); if (slotsVisible) hideSlots("manual"); showSlots(); scheduleNext(); };
    console.log("[SIM] Running. Use forceSlot() to trigger a slot manually.");
})();
</script>
