                        <button id="book-btn" type="submit" disabled style="border-color:#d1d5db;background:#f3f4f6;color:#9ca3af;padding:14px 32px;font-size:20px;border-radius:9999px;font-weight:600;border:1.25px solid;cursor:default;transition:0.3s">Book your appointment</button>
