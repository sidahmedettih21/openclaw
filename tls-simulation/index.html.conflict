    <!-- Log panel -->
    <div class="sim-log-panel" id="simLogPanel" style="position:fixed;bottom:60px;right:16px;width:320px;max-height:200px;overflow:auto;background:#fff;border:1px solid #ccc;border-radius:8px;padding:8px;font-size:12px;z-index:9999;display:none"><div><strong>Event Log</strong></div></div>
    <div style="position:fixed;bottom:16px;right:16px;display:flex;gap:8px;z-index:9999">
        <button onclick="document.getElementById('simLogPanel').style.display=document.getElementById('simLogPanel').style.display==='none'?'block':'none'">📋 Log</button>
        <button onclick="forceSlot()">💺 Force Slot</button>
        <button onclick="resetSimulation()">🔄 Reset</button>
    </div>

    <script>
    (function() {
        const config = {
            freqMin: 15000,
            freqMax: 45000,
            durMin: 3000,
            durMax: 8000,
            slotCount: 3
        };

        let slotsVisible = false, slotsAppearTs = null;
        let slotExpireTimer = null, scheduleTimer = null;
        let targetCard = null, noSlotsMsgParent = null;
        let slotGrid = null;
        let selectedTime = null;

        let logEntries = [];
        function addLog(type, data) {
            const entry = { ts: Date.now(), type, data };
            logEntries.push(entry);
            const panel = document.getElementById('simLogPanel');
            const div = document.createElement('div');
            div.className = 'sim-log-entry';
            const time = new Date(entry.ts).toLocaleTimeString();
            div.innerHTML = `<span class="sim-log-time">[${time}]</span> <span class="sim-log-type ${type}">${type}</span> ${JSON.stringify(data)}`;
            panel.appendChild(div);
            panel.scrollTop = panel.scrollHeight;
        }

        function findTargetCard() {
            const paras = Array.from(document.querySelectorAll('p'));
            const noSlotsPara = paras.find(p => p.textContent.includes('No slots are currently available'));
            if (!noSlotsPara) return null;
            noSlotsMsgParent = noSlotsPara.parentElement;
            let el = noSlotsPara.parentElement;
            while (el && el !== document.body) {
                if (el.getAttribute('style')?.includes('padding-bottom:48px')) return el;
                el = el.parentElement;
            }
            return null;
        }

        function ensureTarget() {
            if (!targetCard) targetCard = findTargetCard();
            return !!targetCard;
        }

        function createSlotGrid() {
            if (!slotGrid) {
                slotGrid = document.createElement('div');
                slotGrid.id = 'sim-slot-grid';
                slotGrid.style.cssText = 'display:flex;flex-wrap:wrap;gap:12px;justify-content:center;padding:20px 0;margin:0 auto;max-width:560px';
            }
            return slotGrid;
        }

        function showSlots() {
            if (slotsVisible || !ensureTarget()) return;
            slotsVisible = true;
            slotsAppearTs = Date.now();
            if (noSlotsMsgParent) noSlotsMsgParent.style.display = 'none';

            const duration = Math.floor(Math.random() * (config.durMax - config.durMin + 1) + config.durMin);
            const times = ['07:30','08:00','08:30','09:00','09:30','10:00','10:30','11:00','11:30','13:00','13:30','14:00','14:30','15:00'];
            const selected = [...times].sort(() => 0.5 - Math.random()).slice(0, config.slotCount);

            const grid = createSlotGrid();
            grid.innerHTML = '';
            selected.forEach(time => {
                const btn = document.createElement('button');
                btn.className = 'sim-slot-btn';
                btn.textContent = time;
                btn.style.cssText = 'background-color:#0057B8;color:#fff;border:none;border-radius:4px;padding:10px 24px;font-size:14px;font-weight:600;cursor:pointer;font-family:inherit;min-width:80px;transition:background-color 0.15s';
                btn.onmouseover = () => { if (!btn.classList.contains('selected')) btn.style.backgroundColor = '#003087'; };
                btn.onmouseout  = () => { if (!btn.classList.contains('selected')) btn.style.backgroundColor = '#0057B8'; };
                btn.onclick = () => onSlotClick(btn, time);
                grid.appendChild(btn);
            });
            if (targetCard.firstChild) targetCard.insertBefore(grid, targetCard.firstChild);
            else targetCard.appendChild(grid);

            addLog('slot_appeared', { slots: selected, durationMs: duration });
            slotExpireTimer = setTimeout(() => hideSlots('expired'), duration);
        }

        function hideSlots(reason) {
            if (!slotsVisible) return;
            slotsVisible = false;
            if (slotExpireTimer) clearTimeout(slotExpireTimer);
            if (slotGrid?.parentNode) slotGrid.remove();
            if (noSlotsMsgParent) noSlotsMsgParent.style.display = '';
            const bookBtn = document.querySelector('button[type="submit"]');
            if (bookBtn) {
                bookBtn.disabled = true;
                bookBtn.style.cssText = 'border-color:rgb(209,213,219);background-color:rgb(243,244,246);color:rgb(156,163,175);cursor:auto';
            }
            addLog('slot_expired', { reason });
        }

        function onSlotClick(btn, time) {
            if (!slotsVisible) return;
            selectedTime = time;
            const reactTime = slotsAppearTs ? Date.now() - slotsAppearTs : null;
            document.querySelectorAll('.sim-slot-btn').forEach(b => {
                b.classList.remove('selected');
                b.style.backgroundColor = '#0057B8';
            });
            btn.classList.add('selected');
            btn.style.backgroundColor = '#003087';
            addLog('slot_clicked', { time, reactTime });
            // Show courier step
            showCourierStep();
        }

        function showCourierStep() {
            document.getElementById('sim-courier-step').style.display = 'flex';
        }

        function hideCourierStep() {
            document.getElementById('sim-courier-step').style.display = 'none';
        }

        document.getElementById('sim-add-courier').addEventListener('click', () => {
            hideCourierStep();
            addLog('courier_added', {});
            showConfirmStep();
        });
        document.getElementById('sim-skip-courier').addEventListener('click', () => {
            hideCourierStep();
            addLog('courier_skipped', {});
            showConfirmStep();
        });

        function showConfirmStep() {
            document.getElementById('sim-confirm-step').style.display = 'flex';
        }

        function hideConfirmStep() {
            document.getElementById('sim-confirm-step').style.display = 'none';
        }

        document.getElementById('sim-book-form').addEventListener('submit', (e) => {
            e.preventDefault();
            hideConfirmStep();
            const totalTime = slotsAppearTs ? Date.now() - slotsAppearTs : null;
            addLog('book_confirmed', { time: selectedTime, totalTime });
            alert('✅ SIMULATION: Appointment booked! The bot would stop here.');
            hideSlots('booked');
        });

        function scheduleNext() {
            const delay = Math.floor(Math.random() * (config.freqMax - config.freqMin + 1) + config.freqMin);
            scheduleTimer = setTimeout(() => {
                if (!slotsVisible) showSlots();
                scheduleNext();
            }, delay);
        }

        window.forceSlot = () => {
            if (scheduleTimer) clearTimeout(scheduleTimer);
            if (slotsVisible) hideSlots('manual');
            showSlots();
            scheduleNext();
        };
        window.downloadLog = () => {
            const dataStr = JSON.stringify(logEntries, null, 2);
            const blob = new Blob([dataStr], {type:'application/json'});
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `simulation_log_${Date.now()}.json`;
            a.click();
            URL.revokeObjectURL(url);
        };
        window.clearLog = () => {
            logEntries = [];
            const panel = document.getElementById('simLogPanel');
            while (panel.children.length > 1) panel.removeChild(panel.lastChild);
            addLog('log_cleared', {});
        };

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', () => setTimeout(() => ensureTarget() && (scheduleNext(), addLog('sim_started', config)), 500));
        } else {
            setTimeout(() => ensureTarget() && (scheduleNext(), addLog('sim_started', config)), 500);
        }
        addLog('init', {});
    })();
    </script>
</body>

</html>
