    // TLScontact full-flow simulation
    let sim = {
        activeMonth: '04-2026',
        selectedDay: null,
        selectedSlot: null,
        slotsVisible: false,
        slotTimer: null,
        log: []
    };

    const months = {
        '03-2026': { days: Array.from({length:31}, (_,i)=>i+1), available: [10,12,15,20,24] },
        '04-2026': { days: Array.from({length:30}, (_,i)=>i+1), available: [5,8,15,22,28] },
        '05-2026': { days: Array.from({length:31}, (_,i)=>i+1), available: [3,7,11,18,25] }
    };

    const timeSlots = ['07:30','08:00','08:30','09:00','09:30','10:00','10:30','11:00','11:30','13:00','13:30','14:00','14:30','15:00'];

    function log(type, data={}) {
        sim.log.push({ ts: Date.now(), type, data });
        const panel = document.getElementById('simLogPanel');
        if (panel.style.display !== 'none') {
            const entry = document.createElement('div');
            entry.innerHTML = `<span style="color:#666">[${new Date().toLocaleTimeString()}]</span> ${type} ${JSON.stringify(data)}`;
            panel.appendChild(entry);
            panel.scrollTop = panel.scrollHeight;
        }
        console.log(`[SIM] ${type}`, data);
    }

    function setMonth(monthStr) {
        sim.activeMonth = monthStr;
        document.querySelectorAll('#sim-month-tabs button').forEach(b => {
            b.classList.toggle('active', b.dataset.month === monthStr);
            if (b.dataset.month !== monthStr) b.disabled = false; // all clickable except active
        });
        renderDays();
    }

    function renderDays() {
        const grid = document.getElementById('sim-day-grid');
        const monthData = months[sim.activeMonth];
        grid.innerHTML = '';
        monthData.days.forEach(day => {
            const btn = document.createElement('button');
            const dateStr = `2026-${sim.activeMonth.split('-')[0]}-${String(day).padStart(2,'0')}`;
            btn.textContent = day;
            btn.dataset.date = dateStr;
            if (monthData.available.includes(day)) {
                btn.className = 'available';
                btn.onclick = () => selectDay(day);
            } else {
                btn.className = 'unavailable';
                btn.disabled = true;
            }
            grid.appendChild(btn);
        });
        grid.style.display = 'grid';
        hideSlots();
        sim.selectedDay = null;
        updateBookButton();
    }

    function selectDay(day) {
        sim.selectedDay = day;
        log('day_selected', { day });
        // Highlight selected day
        document.querySelectorAll('#sim-day-grid button').forEach(b => b.style.outline = 'none');
        const selectedBtn = Array.from(document.querySelectorAll('#sim-day-grid button')).find(b => b.textContent == day && b.classList.contains('available'));
        if (selectedBtn) selectedBtn.style.outline = '2px solid #0a308f';
        showSlots();
    }

    function showSlots() {
        hideSlots();
        const slotGrid = document.getElementById('sim-slot-grid');
        slotGrid.innerHTML = '';
        const shuffled = [...timeSlots].sort(() => 0.5 - Math.random()).slice(0, 3 + Math.floor(Math.random()*3));
        shuffled.forEach(time => {
            const btn = document.createElement('button');
            btn.className = 'sim-slot-btn';
            btn.textContent = time;
            btn.onclick = () => selectSlot(btn, time);
            slotGrid.appendChild(btn);
        });
        slotGrid.style.display = 'flex';
        document.getElementById('no-slots-msg').style.display = 'none';
        sim.slotsVisible = true;
        sim.slotTimer = setTimeout(() => hideSlots(true), 8000 + Math.random()*4000); // auto-expire
        log('slots_shown', { slots: shuffled });
    }

    function hideSlots(expired=false) {
        if (sim.slotTimer) clearTimeout(sim.slotTimer);
        document.getElementById('sim-slot-grid').style.display = 'none';
        if (!expired && !sim.selectedSlot) {
            // Don't show no-slots if day still selected and we just refreshed
            document.getElementById('no-slots-msg').style.display = 'block';
        }
        sim.slotsVisible = false;
        if (expired) log('slots_expired');
    }

    function selectSlot(btn, time) {
        document.querySelectorAll('.sim-slot-btn').forEach(b => { b.classList.remove('selected'); b.style.backgroundColor = '#0057B8'; });
        btn.classList.add('selected');
        btn.style.backgroundColor = '#003087';
        sim.selectedSlot = time;
        log('slot_selected', { time });
        updateBookButton();
    }

    function updateBookButton() {
        const btn = document.getElementById('book-btn');
        if (sim.selectedSlot) {
            btn.disabled = false;
            btn.style.background = '#003087';
            btn.style.color = '#fff';
            btn.style.borderColor = '#003087';
            btn.style.cursor = 'pointer';
        } else {
            btn.disabled = true;
            btn.style.background = '#f3f4f6';
            btn.style.color = '#9ca3af';
            btn.style.borderColor = '#d1d5db';
            btn.style.cursor = 'default';
        }
    }

    // Global functions
    window.forceSlot = () => {
        if (!sim.selectedDay) {
            // Auto-select a day if none chosen
            setMonth('04-2026');
            sim.selectedDay = months['04-2026'].available[0];
            renderDays();
            selectDay(sim.selectedDay);
        } else {
            showSlots();
        }
    };
    window.resetSimulation = () => {
        sim.selectedDay = null;
        sim.selectedSlot = null;
        document.getElementById('sim-slot-grid').style.display = 'none';
        document.getElementById('sim-day-grid').style.display = 'none';
        document.getElementById('no-slots-msg').style.display = 'block';
        updateBookButton();
        log('sim_reset');
    };
    window.downloadLog = () => {
        const blob = new Blob([JSON.stringify(sim.log, null, 2)], {type:'application/json'});
        const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'sim_log.json'; a.click();
    };

    // Initialization
    document.getElementById('courier-continue').addEventListener('click', () => {
        document.getElementById('courier-step').style.display = 'none';
        document.getElementById('appointment-card').classList.remove('hidden');
        setMonth('04-2026'); // Show days for April
        log('courier_continue');
    });

    document.querySelectorAll('#sim-month-tabs button').forEach(btn => {
        btn.addEventListener('click', () => {
            if (!btn.disabled) setMonth(btn.dataset.month);
        });
    });

    document.getElementById('book-btn').addEventListener('click', (e) => {
        e.preventDefault();
        if (!sim.selectedSlot) return;<html>
<head>
<meta charset="UTF-8">
<title>TLScontact Simulation – Portugal Appointment</title>
<style>
  body { margin:0; font-family:'Open Sans',sans-serif; }
  .courier-overlay { position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); display:flex; align-items:center; justify-content:center; z-index:100; }
  .courier-box { background:#fff; padding:24px; border-radius:8px; text-align:center; max-width:400px; }
  .courier-box p { font-size:18px; margin-bottom:16px; }
  .courier-box button { padding:12px 32px; font-size:16px; background-color:#0a308f; color:#fff; border:none; border-radius:8px; cursor:pointer; font-weight:600; }
  .hidden { display:none !important; }
  #sim-month-tabs { display:flex; overflow:hidden; align-items:center; padding:0 16px; }
  #sim-month-tabs button { flex:1; padding:8px; text-align:center; font-weight:700; border-radius:8px; border:none; background:transparent; color:#536eb1; font-size:16px; cursor:pointer; transition:0.5s; }
  #sim-month-tabs button.active { transform:scale(1.5); color:#0a308f; opacity:1; }
  #sim-month-tabs button:disabled { opacity:0.3; cursor:default; }
  #sim-day-grid { display:grid; grid-template-columns:repeat(7,1fr); gap:4px; max-width:100%; margin:0 auto; padding:16px 0; }
  #sim-day-grid button { padding:10px 0; border:1px solid #d1d5db; border-radius:4px; background:#fff; font-size:14px; cursor:pointer; }
  #sim-day-grid button.available { background:#e0f2fe; border-color:#38bdf8; color:#0369a1; font-weight:600; }
  #sim-day-grid button.unavailable { opacity:0.4; cursor:default; background:#f3f4f6; }
  #sim-slot-grid { display:flex; flex-wrap:wrap; gap:12px; justify-content:center; padding:20px 0; max-width:560px; margin:0 auto; }
  .sim-slot-btn { background-color:#0057B8; color:#fff; border:none; border-radius:4px; padding:10px 24px; font-size:14px; font-weight:600; cursor:pointer; min-width:80px; transition:background 0.15s; }
  .sim-slot-btn.selected { background-color:#003087; }
  .book-btn-disabled { border-color:#d1d5db; background-color:#f3f4f6; color:#9ca3af; cursor:auto; }
</style>
</head>
