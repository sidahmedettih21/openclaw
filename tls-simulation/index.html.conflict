        <footer style="background:#0a308f;padding:32px 24px;color:#fff;position:relative">
            <div style="max-width:1536px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr 1fr;gap:32px;font-size:14px">
                <div><p style="font-weight:700">Centre Information</p><a style="color:#fff;display:block">Added Value Services</a><a style="color:#fff;display:block">Address and opening hours</a><a style="color:#fff;display:block">Contact Us</a></div>
                <div><p style="font-weight:700">Visa Information</p><a style="color:#fff;display:block">Application Process</a><a style="color:#fff;display:block">Documents and Visa Types</a><a style="color:#fff;display:block">Application Fees</a><a style="color:#fff;display:block">Links and Downloads</a></div>
                <div><p style="font-weight:700">General/Legal</p><a style="color:#fff;display:block">FAQ</a><a style="color:#fff;display:block">News</a><a style="color:#fff;display:block">Security Notice</a><a style="color:#fff;display:block">Privacy Notice</a><a style="color:#fff;display:block">Terms of Service</a><a style="color:#fff;display:block">Cookies Policy</a></div>
