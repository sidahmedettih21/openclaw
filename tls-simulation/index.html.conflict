                                <svg width="25" height="25" viewBox="0 0 25 25" fill="none" style="fill:rgb(245,210,0)"><path fill-rule="evenodd" d="M1.69531 2.38281C1.69531 1.9686 2.0311 1.63281 2.44531 1.63281H4.14219C4.14458 1.63281 4.14698 1.63282 4.14937 1.63285C4.4992 1.6362 4.83685 1.76172 5.10392 1.9877C5.37055 2.21331 5.55007 2.52487 5.61157 2.86865C5.61167 2.86922 5.61177 2.86978 5.61187 2.87035L8.11496 16.6328H18.1953C18.6095 16.6328 18.9453 16.9686 18.9453 17.3828C18.9453 17.797 18.6095 18.1328 18.1953 18.1328H7.48906C7.12661 18.1328 6.81603 17.8736 6.75117 17.517L4.13554 3.13577L4.13501 3.13281H2.44531C2.0311 3.13281 1.69531 2.79703 1.69531 2.38281Z"/><path fill-rule="evenodd" d="M8.44531 18.1328C7.82399 18.1328 7.32031 18.6365 7.32031 19.2578C7.32031 19.8791 7.82399 20.3828 8.44531 20.3828C9.06663 20.3828 9.57031 19.8791 9.57031 19.2578C9.57031 18.6365 9.06663 18.1328 8.44531 18.1328ZM5.82031 19.2578C5.82031 17.8081 6.99556 16.6328 8.44531 16.6328C9.89506 16.6328 11.0703 17.8081 11.0703 19.2578C11.0703 20.7076 9.89506 21.8828 8.44531 21.8828C6.99556 21.8828 5.82031 20.7076 5.82031 19.2578Z"/><path fill-rule="evenodd" d="M18.1953 18.1328C17.574 18.1328 17.0703 18.6365 17.0703 19.2578C17.0703 19.8791 17.574 20.3828 18.1953 20.3828C18.8166 20.3828 19.3203 19.8791 19.3203 19.2578C19.3203 18.6365 18.8166 18.1328 18.1953 18.1328ZM15.5703 19.2578C15.5703 17.8081 16.7456 16.6328 18.1953 16.6328C19.6451 16.6328 20.8203 17.8081 20.8203 19.2578C20.8203 20.7076 19.6451 21.8828 18.1953 21.8828C16.7456 21.8828 15.5703 20.7076 15.5703 19.2578Z"/><path fill-rule="evenodd" d="M4.69531 6.13281C4.69531 5.7186 5.0311 5.38281 5.44531 5.38281H21.1953C21.4178 5.38281 21.6288 5.48157 21.7713 5.6524C21.9137 5.82324 21.9731 6.04851 21.9331 6.26736L20.7898 12.5368C20.7898 12.5373 20.7897 12.5377 20.7896 12.5382C20.6965 13.0564 20.424 13.5253 20.0197 13.8626C19.6154 14.1999 19.1052 14.3841 18.5787 14.3828H6.80469C6.39047 14.3828 6.05469 14.047 6.05469 13.6328C6.05469 13.2186 6.39